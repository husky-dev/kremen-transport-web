{
  "name": "kremen-transport-web",
  "version": "1.0.2",
  "main": "index.js",
  "author": "Jaroslav Khorishchenko <jaro@husky-dev.me>",
  "license": "MIT",
  "scripts": {
    "start": "node esbuild.js --serve",
    "dist": "node esbuild.js",
    "test": "jest",
    "lint": "npm run lint:types && npm run lint:eslint && npm run lint:format",
    "lint:types": "tsc --build --noEmit",
    "lint:types:watch": "tsc --build --noEmit --watch",
    "lint:eslint": "eslint src --fix",
    "lint:format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "snippets": "npx md2snipp --root .vscode/snippets --output .vscode",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "@tailwindcss/postcss": "4.2.3",
    "@tailwindcss/typography": "0.5.19",
    "@vis.gl/react-google-maps": "1.8.3",
    "axios": "1.15.1",
    "color": "5.0.3",
    "daisyui": "5.5.19",
    "dompurify": "3.4.0",
    "marked": "18.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.1",
    "tailwindcss": "^4.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/color": "4.2.1",
    "@types/googlemaps": "3.43.3",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "autoprefixer": "10.5.0",
    "esbuild": "0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "tmp": "0.2.5",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "zod": "4.3.6"
  }
}
